    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\n\n// Группируем по ученику, берём только слова:\n// - с отмеченной галочкой \"В квиз\"\n// - с пустой колонкой \"Квиз\"\nconst byStudent = {};\n\nfor (const r of rows) {\n  const student = String(r['Ученик'] || '').trim();\n  const quizzed = String(r['Квиз'] || '').trim();\n  const word = String(r['Слово / фраза'] || '').trim();\n  const include = r['В квиз'];\n\n  if (!student || !word) continue;\n  if (quizzed !== '') continue;\n  if (include !== true) continue;\n\n  if (!byStudent[student]) {\n    byStudent[student] = {\n      words: [],\n      rowNumbers: []\n    };\n  }\n\n  byStudent[student].words.push(word);\n  byStudent[student].rowNumbers.push(r.row_number);\n}\n\nconst today = new Date().toLocaleDateString('ru-RU');\nconst out = [];\n\nfor (const student of Object.keys(byStudent)) {\n  const words = byStudent[student].words;\n\n  if (!words.length) continue;\n\n  const prompt = `\nYou are an experienced English teacher creating a short weekly vocabulary quiz.\n\nStudent: ${student}\n\nThe student has already learned these expressions in live lessons.\n\nThe goal is retrieval practice, not teaching.\n\nThe quiz will be sent directly to the student in Telegram.\n\nGENERAL RULES\n\n• Never translate.\n• Never explain vocabulary.\n• Use natural conversational American English.\n• Sound like a friendly teacher.\n• Keep the whole quiz short (3–5 minutes).\n• Every week's quiz should feel fresh.\n• Surprise the teacher with creative but realistic questions.\n\n────────────────────────\n\nCreate EXACTLY 5 questions.\n\nUse FIVE different task types.\n\nChoose naturally from:\n\n• Fill in the blank\n• Multiple choice\n• Rewrite\n• What would you say?\n• Finish the dialogue\n• Choose the most natural sentence\n• Spot the mistake\n• Mini scenario\n• Finish the sentence\n• React naturally\n\nNever repeat the same task type.\n\n────────────────────────\n\nDifficulty\n\nQuestion 1 → very easy\n\nQuestion 2 → easy\n\nQuestion 3 → medium\n\nQuestion 4 → medium\n\nQuestion 5 → the most challenging\n\n────────────────────────\n\nQuestion rules\n\n• Every target expression must appear at least once.\n\n• At least ONE task must require the student to write their own answer.\n\n• Multiple choice distractors should be believable.\n\n• Whenever possible, use other target expressions as distractors.\n\n• Avoid obviously wrong answers.\n\n• Contexts should feel like real adult life:\nwork, relationships, travel, technology, films, social media, hobbies, money, everyday conversations.\n\n• Vary sentence openings.\n\n• Avoid repeating wording like:\n\"Fill in the blank...\"\n\"Choose...\"\n\"What would you say...\"\n\n────────────────────────\n\nOUTPUT FORMAT\n\nWrite ONE friendly introductory sentence.\n\nThen the five numbered questions.\n\nAt the end write:\n\nAnswers\n\nand provide a clean answer key only.\n\nDo not explain why the answers are correct.\n\nDo not use Markdown.\n\nTarget vocabulary:\n\n${words.join('\\n')}\n`;\n\n  out.push({\n    json: {\n      student,\n      count: words.length,\n      rowNumbers: byStudent[student].rowNumbers,\n      today,\n      promptText: prompt\n    }\n  });\n}\n\nreturn out;"
      },
