      "parameters": {
        "jsCode": "const students = $('Собрать квизы').all().map(i => i.json);\n\nconst out = [];\n\nfor (const s of students) {\n  const today = s.today;\n\n  for (const rn of (s.rowNumbers || [])) {\n    out.push({\n      json: {\n        row_number: rn,\n        \"Квиз\": today,\n        \"В квиз\": false\n      }\n    });\n  }\n}\n\nreturn out;"
